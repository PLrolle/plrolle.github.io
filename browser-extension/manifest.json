{
  "manifest_version": 3,
  "name": "plrolle / link curator",
  "description": "Sauvegarde un lien vers plrolle.github.io/links avec résumé Claude",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.github.com/*"
  ]
}
